# LLM Provider: 'ollama', 'nvidia', or 'openai'
LLM_PROVIDER=ollama

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PERPLEXITY_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
MAX_CONCURRENT_OLLAMA_CALLS=3

# NVIDIA NIM Configuration
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_GENERATION_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small

# General RAG Configuration
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION=asc_collection
LOG_LEVEL=INFO
PERPLEXITY_CONTEXT_WINDOW=3
Z_SCORE_THRESHOLD=2.0
MIN_CHUNK_SENTENCES=3
